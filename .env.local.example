# Google OAuth — from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Turso Database — from https://turso.tech/app
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# DB init route protection (set to any random string)
INIT_SECRET=your_random_init_secret

# api keys for audio transcribing
ELEVENLABS_API_KEY=your_elevenlabs_api_key
GEMINI_API_KEY=your_key_here
